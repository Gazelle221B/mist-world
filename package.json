{
  "name": "mist-world",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "wasm:build:wfc": "cd rust/mist-wfc && wasm-pack build --target web --out-dir ../../src/wasm/mist-wfc",
    "wasm:build:crypto": "cd rust/mist-crypto && wasm-pack build --target web --out-dir ../../src/wasm/mist-crypto"
  },
  "dependencies": {
    "@babylonjs/core": "8.55.2",
    "@babylonjs/gui": "8.55.2",
    "@babylonjs/havok": "1.3.12",
    "@babylonjs/loaders": "8.55.2",
    "@babylonjs/materials": "8.55.2",
    "@msgpack/msgpack": "3.1.3",
    "@yoursunny/webcrypto-ed25519": "0.0.20250208",
    "honeycomb-grid": "4.1.5",
    "loro-crdt": "1.10.7"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-top-level-await": "1.6.0",
    "vite-plugin-wasm": "3.6.0"
  }
}
